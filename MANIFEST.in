include README.md
include LICENSE
include RELEASES.md
include CLAUDE.md
recursive-include easycord *.py
recursive-include easycord *.typed
recursive-include docs *.md
recursive-include examples *.py
exclude .claude
exclude .worktrees
exclude .git
exclude tests
exclude .github
exclude .gitignore
exclude setup.py
exclude tox.ini
prune __pycache__
prune .pytest_cache
prune .mypy_cache
prune *.egg-info
